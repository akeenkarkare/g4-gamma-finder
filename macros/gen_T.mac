# Generate a random-sampled training dataset for the T-shape tetromino.
# ~1000 configs x 5000 events. Output: ds_T_nt_pixels_t0.csv
/det/shape T
/det/padding 1.0 mm
/run/numberOfThreads 1
/run/initialize
/run/verbose 0
/event/verbose 0
/tracking/verbose 0
/gun/particle gamma
/gun/energy 0.5 MeV
/det/openFile ds_T
/control/loop gen_config_step.mac i 1 1000 1
/det/writeFile
